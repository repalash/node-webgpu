{
  "name": "@repalash/webgpu",
  "version": "0.4.10001",
  "description": "WebGPU for Node — fork of dawn-gpu/node-webgpu `webgpu` with Alpine/musl binaries",
  "main": "index.js",
  "type": "module",
  "types": "types.d.ts",
  "scripts": {
    "build": "node build/build.js",
    "compile": "node build/build.js --compile-only",
    "cts": "node build/run-cts.js",
    "postinstall": "node build/postinstall.js",
    "test": "node test/test.js",
    "update": "node build/update.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/repalash/node-webgpu.git"
  },
  "keywords": [
    "WGSL",
    "WebGPU",
    "alpine",
    "musl"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/repalash/node-webgpu/issues"
  },
  "homepage": "https://github.com/repalash/node-webgpu#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "build/**/*",
    "index.js",
    "types.d.ts"
  ],
  "dependencies": {
    "@webgpu/types": "^0.1.69",
    "debug": "^4.4.0",
    "detect-libc": "^2.1.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  }
}
